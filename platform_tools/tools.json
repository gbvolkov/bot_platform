{
  "tool_guardrail_profiles": {
    "external_public_no_result_anonymization": {
      "allowed_roles": [
        "default",
        "service_desk",
        "sales_manager"
      ],
      "side_effect": "read",
      "category": "external_access",
      "sensitivity": "public",
      "allow_external_access": true,
      "anonymize_result": false,
      "result_policy": {
        "scan_result": true,
        "max_text_chars": 12000,
        "max_items": 10
      }
    },
    "external_confidential_anonymize_result": {
      "allowed_roles": [
        "default",
        "service_desk",
        "sales_manager"
      ],
      "side_effect": "read",
      "category": "external_access",
      "sensitivity": "confidential",
      "allow_external_access": true,
      "anonymize_result": true,
      "result_policy": {
        "scan_result": true,
        "max_text_chars": 12000,
        "max_items": 10
      }
    }
  },
  "internal_tools": [
    {
      "id": "fetch_user_info",
      "import": "agents.user_info:fetch_user_info"
    },
    {
      "id": "lookup_term",
      "factory": "agents.retrievers.retriever:get_term_and_defition_tools"
    },
    {
      "id": "search_kb",
      "factory": "agents.retrievers.retriever:get_search_tool"
    },
    {
      "id": "search_tickets",
      "factory": "agents.retrievers.retriever:get_tickets_search_tool"
    },
    {
      "id": "store_artifact_tool",
      "import": "agents.tools.store:store_artifact_tool"
    },
    {
      "id": "web_search_tool",
      "factory": "agents.tools.yandex_search:YandexSearchTool",
      "guardrail_profile": "external_public_no_result_anonymization",
      "params": {
        "api_key": "${YA_API_KEY}",
        "folder_id": "${YA_FOLDER_ID}",
        "max_results": 5,
        "summarize": true
      }
    },
    {
      "id": "web_search_public",
      "factory": "agents.tools.yandex_search:YandexSearchTool",
      "guardrail_profile": "external_public_no_result_anonymization",
      "params": {
        "name": "web_search_public",
        "api_key": "${YA_API_KEY}",
        "folder_id": "${YA_FOLDER_ID}",
        "max_results": 5,
        "summarize": true
      }
    },
    {
      "id": "web_search_private",
      "factory": "agents.tools.yandex_search:YandexSearchTool",
      "guardrail_profile": "external_confidential_anonymize_result",
      "params": {
        "name": "web_search_private",
        "api_key": "${YA_API_KEY}",
        "folder_id": "${YA_FOLDER_ID}",
        "max_results": 5,
        "summarize": true
      }
    },
    {
      "id": "think_tool",
      "factory": "agents.tools.think:ThinkTool"
    }
  ],
  "mcp_servers": [
    {
      "id": "googleapis_maps",
      "name": "maps",
      "aliases": ["maps", "google_maps"],
      "transport": "http",
      "url": "https://mapstools.googleapis.com/mcp",
      "timeout": 90,
      "sse_read_timeout": 300,
      "headers": {
        "X-Goog-Api-Key": "${GOOGLE_MAPS_GROUNDING_LITE_API_KEY}"
      },
      "tool_name_prefix": true,
      "guardrail_profiles": {
        "maps_search_places": "external_public_no_result_anonymization"
      }
    },
    {
      "id": "gmail",
      "name": "gmail",
      "transport": "stdio",
      "command": "npx",
      "args": ["@shinzolabs/gmail-mcp"],
      "env": {
        "CLIENT_ID": "${GMAIL_MCP_CLIENT_ID}",
        "CLIENT_SECRET": "${GMAIL_MCP_CLIENT_SECRET}",
        "REFRESH_TOKEN": "${GMAIL_MCP_REFRESH_TOKEN}",
        "TELEMETRY_ENABLED": "false",
        "PORT": "3001"
      },
      "tool_name_prefix": true
    },
    {
      "id": "nhtsa",
      "name": "nhtsa",
      "transport": "http",
      "url": "https://nhtsa.caseyjhand.com/mcp",
      "tool_name_prefix": false
    }
  ]
}
