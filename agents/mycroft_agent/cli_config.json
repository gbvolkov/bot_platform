{
  "system_prompt": {
    "type": "file",
    "path": "gaz_sales_system_prompt.txt"
  },
  "skills": {
    "paths": [
      "skills/mycroft"
    ]
  },
  "subagents": {
    "stateless": [
      "gaz_pricing_bi_int",
      "marketing_analyst",
      "web_search_agent"
    ],
    "stateful": []
  },
  "internal_tools": [
    "store_artifact_tool"
  ],
  "deepagents": {
    "interrupt_on": {
      "gmail_send_message": {
        "allowed_decisions": [
          "approve",
          "edit",
          "reject"
        ],
        "description": "Review outbound Gmail send before execution."
      }
    }
  },
  "mcp": {
    "tool_name_prefix": true,
    "servers": [
      {
        "name": "maps",
        "transport": "http",
        "url": "https://mapstools.googleapis.com/mcp",
        "headers": {
          "X-Goog-Api-Key": "${GOOGLE_MAPS_GROUNDING_LITE_API_KEY}"
        },
        "tools": [
          "search_places",
          "compute_routes"
        ]
      },
      {
        "name": "gmail",
        "transport": "stdio",
        "command": "npx",
        "args": [
          "@shinzolabs/gmail-mcp"
        ],
        "env": {
          "CLIENT_ID": "${GMAIL_MCP_CLIENT_ID}",
          "CLIENT_SECRET": "${GMAIL_MCP_CLIENT_SECRET}",
          "REFRESH_TOKEN": "${GMAIL_MCP_REFRESH_TOKEN}",
          "TELEMETRY_ENABLED": "false"
        },
        "tools": [
          "create_draft",
          "send_message"
        ]
      },
      {
        "name": "nhtsa",
        "transport": "http",
        "url": "https://nhtsa.caseyjhand.com/mcp",
        "tool_name_prefix": false,
        "tools": [
          "nhtsa_decode_vin",
          "nhtsa_search_recalls"
        ]
      }
    ]
  }
}
