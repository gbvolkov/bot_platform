# Copy this file to .env and fill secret values locally.
#
# Minimal OpenAI-based setup. This is the smallest config for a rebuild because
# the reused GAZ runtime uses embeddings plus LLM table/image summaries.

OPENAI_API_KEY=

LLM_PROVIDER=openai
LLM_MODEL=mini

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small

# Optional:
# LANGCHAIN_TRACING_V2=false
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Optional Yandex Object Storage sync settings for
# scripts/sync_yandex_gaz_docs_and_build.sh
YANDEX_OBJECT_STORAGE_BUCKET=
YANDEX_OBJECT_STORAGE_PREFIX=gaz-docs
YANDEX_OBJECT_STORAGE_ENDPOINT=https://storage.yandexcloud.net

# AWS CLI credentials/profile for Yandex Object Storage S3-compatible API.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=

GAZ_DOCS_ROOT=./data/gaz-docs
GAZ_INDEX_ROOT=./data/gaz-index
GAZ_COLLECTION_ID=gaz
GAZ_SYNC_DELETE=0
GAZ_INDEX_FORCE=1
