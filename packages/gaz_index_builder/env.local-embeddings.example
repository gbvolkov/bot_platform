# Copy this file to .env and fill secret values locally.
#
# Uses local/Hugging Face embeddings for vectorization, while keeping OpenAI for
# table/image summaries produced by the reused GAZ runtime.

OPENAI_API_KEY=

LLM_PROVIDER=openai
LLM_MODEL=mini

EMBEDDING_PROVIDER=huggingface
EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-large

# Optional when the model is already cached locally:
# HF_HUB_OFFLINE=1
# TRANSFORMERS_OFFLINE=1

# Optional Yandex Object Storage sync settings for
# scripts/sync_yandex_gaz_docs_and_build.sh
YANDEX_OBJECT_STORAGE_BUCKET=gbv-gazsales
YANDEX_OBJECT_STORAGE_PREFIX=gaz-docs
YANDEX_OBJECT_STORAGE_ENDPOINT=https://storage.yandexcloud.net
YANDEX_CLOUD_FOLDER_ID=b1gt23jcnbib316dc05q
YANDEX_OBJECT_STORAGE_RESOURCE_ID=e3e3b2vb681dc13mlm7i
YANDEX_OBJECT_STORAGE_CLASS=STANDARD
YANDEX_OBJECT_STORAGE_VERSIONING=disabled
YANDEX_OBJECT_STORAGE_CREATED_AT=2026-05-22T13:02:12.984088Z

# AWS CLI credentials/profile for Yandex Object Storage S3-compatible API.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=

GAZ_DOCS_ROOT=./data/gaz-docs
GAZ_INDEX_ROOT=./data/gaz-index
GAZ_COLLECTION_ID=gaz
GAZ_SYNC_DELETE=0
GAZ_INDEX_FORCE=1
